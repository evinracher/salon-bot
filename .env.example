# Used by Docker Compose for the Postgres container (see compose.yml)
DB_USER=user
DB_PASSWORD=password
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=salon_bot

# Required by the app (SQLAlchemy async URL). Must match your Compose credentials/host/port.
DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5433/salon_bot

# Required by pytest (same Postgres, test database). Root conftest loads .env then reads this.
TEST_DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5433/salon_bot_test

APP_PORT=8000

TIMEZONE=America/Bogota
SLOT_INTERVAL_MINUTES=30
BUSINESS_OPEN_TIME=10:00
BUSINESS_CLOSE_TIME=19:00
BUSINESS_DAYS=mon,tue,wed,thu,fri,sat

# Chat agent LLM: groq | openai (case-insensitive)
CHAT_LLM_PROVIDER=groq

# Groq (when CHAT_LLM_PROVIDER=groq)
# GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Optional: comma-separated fallback Groq models on 429 rate limit
# GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile

# OpenAI (when CHAT_LLM_PROVIDER=openai). One line, no spaces around = value; no quotes around the key unless needed.
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Redis (BullMQ background jobs — compose.yml exposes redis on 6379)
REDIS_URL=redis://127.0.0.1:6379/0

# Meta WhatsApp Cloud API (webhook + outbound messages)
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v21.0

# Optional BullMQ tuning
WHATSAPP_QUEUE_NAME=whatsapp-inbound
WHATSAPP_WORKER_CONCURRENCY=2
WHATSAPP_JOB_ATTEMPTS=3
