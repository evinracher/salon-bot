# Used by Docker Compose for the Postgres container (see compose.yml)
DB_USER=user
DB_PASSWORD=password
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=salon_bot

# Required by the app (SQLAlchemy async URL). Must match your Compose credentials/host/port.
DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5433/salon_bot

# Required by pytest (same Postgres, test database). Root conftest loads .env then reads this.
TEST_DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5433/salon_bot_test

APP_PORT=8000

TIMEZONE=America/Bogota
SLOT_INTERVAL_MINUTES=30
BUSINESS_OPEN_TIME=10:00
BUSINESS_CLOSE_TIME=19:00
BUSINESS_DAYS=mon,tue,wed,thu,fri,sat
